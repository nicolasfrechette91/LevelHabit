{
  "ConnectionStrings": {
    "DefaultConnection": "CHANGE_ME"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://nicolasfrechette91.github.io"
    ]
  },
  "Jwt": {
    "Issuer": "LevelHabit.Api",
    "Audience": "LevelHabit.Frontend",
    "ExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30,
    "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
  },
  "AuthCookies": {
    "RefreshTokenName": "LevelHabit.Refresh",
    "CsrfTokenName": "LevelHabit.Csrf",
    "Secure": true,
    "SameSite": "None"
  },
  "Email": {
    "Provider": "Brevo"
  },
  "EmailVerification": {
    "CodeExpirationMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaximumFailedAttempts": 5
  },
  "Brevo": {
    "SenderEmail": "your-verified-sender-email",
    "SenderName": "LevelHabit"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },
  "Sentry": {
    "Dsn": "",
    "Environment": "production"
  }
}
